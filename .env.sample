# =================================================================
#  LLM Crawler Agent - 환경 변수 설정
# =================================================================

# --- [필수] LLM 역할별 제공자 설정 ---
# 라우팅(경로탐색) LLM: 빠른 응답이 중요 (gemini 권장)
ROUTING_LLM_PROVIDER="gemini"

# 분석(후처리) LLM: 정확도가 중요 (local 권장)
ANALYSIS_LLM_PROVIDER="local"


# --- [API 사용 시 필수] ---
# ROUTING_LLM_PROVIDER 또는 ANALYSIS_LLM_PROVIDER에 "gemini" 사용 시 API 키를 입력하세요.
GEMINI_API_KEY="여기에_당신의_Gemini_API_키를_입력하세요"


# --- [선택] 모델 이름 지정 ---
# 라우팅에 사용할 Gemini 모델 이름
ROUTING_GEMINI_MODEL="gemini-1.5-flash"

# 분석에 사용할 로컬 LLM(Ollama) 모델 이름
ANALYSIS_LOCAL_MODEL="llama3"


# --- [선택] 크롤링 엔진 설정 ---
# aiohttp: 고성능 순수 비동기 엔진 (기본값)
# hybrid: requests 기반의 안정적인 하이브리드 엔진
CRAWLER_ENGINE="aiohttp"


# --- [선택] 주요 크롤링 설정 ---
MAX_PAGES_PER_SESSION=20
RELEVANCE_THRESHOLD=0.7
REQUEST_DELAY=1.5