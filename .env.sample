# =================================================================
#  LLM Crawler Agent - 환경 변수 설정
# =================================================================
# 이 파일을 복사하여 '.env' 파일을 만든 후, 아래 값들을 설정하세요.
# -----------------------------------------------------------------

# [필수] 사용할 LLM 제공자를 선택합니다. (옵션: gemini, local)
# 로컬 테스트 시에는 "local", Gemini API 사용 시에는 "gemini"로 설정하세요.
LLM_PROVIDER="local"

# [Gemini 사용 시 필수] Google Gemini API 키를 입력하세요.
GEMINI_API_KEY="AIzaSyD5f4FAEH3EvVKWCJVzLH-ob4j9bC8M5sw"

# [로컬 LLM 사용 시] Ollama에서 사용할 모델 이름을 지정합니다.
LOCAL_LLM_MODEL="llama3"


# --- [선택] 주요 크롤링 설정 (테스트 시 자주 변경하는 값) ---

# 한 사이트에서 최대 크롤링할 페이지 수
MAX_PAGES_PER_SESSION=20

# LLM이 평가하는 관련성 임계값 (0.0 ~ 1.0)
RELEVANCE_THRESHOLD=0.7

# 각 페이지 요청 사이의 대기 시간 (초)
REQUEST_DELAY=1.5

# -----------------------------------------------------------------
# ※ 이 외의 모든 설정(타임아웃, RabbitMQ 등)은 'config/settings.py'에
#    기본값이 정의되어 있으며, 필요 시 .env 파일에 추가하여 덮어쓸 수 있습니다.
# -----------------------------------------------------------------